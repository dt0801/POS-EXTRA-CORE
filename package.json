{
  "name": "bbq-pos",
  "version": "1.0.0",
  "description": "POS System – Tiệm Nướng Đà Lạt Và Em",
  "scripts": {
    "start": "npm run server",
    "dev": "concurrently \"npm run server\" \"npm run react\"",
    "server": "node server.js",
    "react": "cd pos-ui && npm start",
    "build": "cd pos-ui && npm run build",
    "migrate:uploads-to-cloudinary": "node scripts/upload-local-images-to-cloudinary.js",
    "migrate:cloudinary-to-mongo": "node scripts/sync-cloudinary-folder-to-mongo.js",
    "postinstall": "echo web-only mode",
    "electron": "electron electron/main.js"
  },
  "dependencies": {
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mongodb": "^7.1.1",
    "multer": "^1.4.5-lts.1",
    "node-thermal-printer": "^4.3.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^34.5.8"
  },
  "author": "BBQ POS"
}
